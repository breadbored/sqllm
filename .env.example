# =============================================================================
# SQLLM environment configuration
# Copy to .env and fill in values. CLI flags override .env, .env overrides
# config file defaults.
# =============================================================================

# --- inference ---

# GTX 1080 local (current test environment)
OLLAMA_BASE_URL=http://192.168.50.247:11434
# RX 9070 XT remote — update when available
# OLLAMA_BASE_URL=http://192.168.x.x:11434

# GTX 1080 test model (Q4_K_M, ~4.5GB)
OLLAMA_MODEL=qwen2.5-coder:7b
# RX 9070 XT production model
# OLLAMA_MODEL=qwen2.5-coder:12b

OLLAMA_TEMPERATURE=0.7
OLLAMA_CONTEXT_LENGTH=8192

# --- backends ---

# Default backend: ollama | claude
INFERENCE_BACKEND=ollama

# Claude Code model for --backend claude: haiku | sonnet | opus
CLAUDE_MODEL=sonnet

# Anthropic API key — alternative to `claude login` for Claude backend
# ANTHROPIC_API_KEY=sk-ant-...

# --- corpus ---

# Directory where JSONL corpus files are written
CORPUS_DIR=../corpus

# --- training ---
# bf16=false, fp16=true  for GTX 1080 (Pascal — no bf16 support)
# bf16=true,  fp16=false for RX 9070 XT
